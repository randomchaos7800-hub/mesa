{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MESA v1 Benchmark Item",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "type", "question", "expected_answer", "sessions"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^mesa-[a-z][a-z-]*-[0-9]{4}$",
        "description": "Unique item ID, e.g. mesa-recall-single-0001"
      },
      "type": {
        "type": "string",
        "enum": [
          "recall/single",
          "recall/preference",
          "recall/constraint",
          "synthesis/multi",
          "temporal",
          "update",
          "update/interference",
          "adversarial",
          "causal"
        ]
      },
      "question": {
        "type": "string",
        "minLength": 10
      },
      "expected_answer": {
        "type": "string",
        "minLength": 1
      },
      "sessions": {
        "description": "Conversation content to inject. Two formats are supported:\n  Single-session: a flat list of turn objects {role, content}.\n  Multi-session: a list of session objects {date, turns} where each session\n  occurred on a different date. Use multi-session for temporal items that\n  require reasoning across time (e.g. facts stated/updated on different days).",
        "oneOf": [
          {
            "type": "array",
            "title": "Single-session (flat turn list)",
            "items": {
              "type": "object",
              "required": ["role", "content"],
              "additionalProperties": false,
              "properties": {
                "role": { "type": "string", "enum": ["user", "assistant"] },
                "content": { "type": "string", "minLength": 1 }
              }
            }
          },
          {
            "type": "array",
            "title": "Multi-session (list of dated sessions)",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["date", "turns"],
              "additionalProperties": false,
              "properties": {
                "date": {
                  "type": "string",
                  "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
                  "description": "ISO date of this conversation session"
                },
                "turns": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["role", "content"],
                    "additionalProperties": false,
                    "properties": {
                      "role": { "type": "string", "enum": ["user", "assistant"] },
                      "content": { "type": "string", "minLength": 1 }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "metadata": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "enum": ["sessions", "finetune", "lighthouse", "handcrafted"],
            "description": "Where this item came from"
          },
          "date_added": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "notes": { "type": "string" },
          "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] }
        }
      }
    }
  }
}
